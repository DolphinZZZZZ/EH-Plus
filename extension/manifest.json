{
  "manifest_version": 3,
  "name": "EH＋",
  "version": "1.0.1",
  "description": "EH的网页增强插件",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "downloads",
    "webNavigation",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://e-hentai.org/*",
    "https://exhentai.org/*",
    "https://*.hath.network/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "EH＋",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://e-hentai.org/s/*",
        "https://exhentai.org/s/*"
      ],
      "js": [
        "reader-nl-guard-main.js",
        "reader-cache-first-main.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://e-hentai.org/g/*",
        "https://e-hentai.org/s/*",
        "https://exhentai.org/g/*",
        "https://exhentai.org/s/*"
      ],
      "js": [
        "runtime-owner-main.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://e-hentai.org/g/*",
        "https://e-hentai.org/s/*",
        "https://exhentai.org/g/*",
        "https://exhentai.org/s/*"
      ],
      "js": [
        "content-script.js"
      ],
      "css": [
        "content-style.css"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "images/autopager/donw.png",
        "images/autopager/down_gray.png",
        "images/autopager/to_bottom.png",
        "images/autopager/to_top.png",
        "images/autopager/up.png",
        "images/autopager/up_gray.png",
        "images/cache-first-placeholder.svg"
      ],
      "matches": [
        "https://e-hentai.org/*",
        "https://exhentai.org/*"
      ]
    }
  ]
}
